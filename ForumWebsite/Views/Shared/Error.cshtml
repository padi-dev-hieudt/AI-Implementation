@model ErrorViewModel
@{
    ViewData["Title"] = "Lỗi";
}

<div class="error-page-wrap">
    <div class="error-page-card">
        <div class="forum-card p-5 text-center">
            <i class="bi bi-exclamation-triangle-fill fs-1 text-danger d-block mb-3"></i>
            <h4 class="fw-bold mb-2">Đã xảy ra lỗi</h4>
            <p class="text-muted mb-0">Có lỗi trong khi xử lý yêu cầu của bạn.</p>

            @if (Model.ShowRequestId)
            {
                <p class="text-muted small mt-2 mb-0">
                    <strong>Request ID:</strong> <code>@Model.RequestId</code>
                </p>
            }

            <div class="mt-4 d-flex justify-content-center gap-2">
                <a href="/" class="btn btn-primary">
                    <i class="bi bi-house me-1"></i>Trang chủ
                </a>
                <a href="#" id="btnGoBack" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Quay lại
                </a>
            </div>
        </div>
    </div>
</div>
