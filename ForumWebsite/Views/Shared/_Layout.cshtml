<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Forum</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<!-- ═══════════════════════════ NAVBAR ═══════════════════════════ -->
<nav class="navbar navbar-expand-lg forum-navbar sticky-top">
    <div class="container-xl">

        <a class="navbar-brand forum-brand" href="/">
            <i class="bi bi-chat-square-dots-fill me-2"></i>Forum
        </a>

        <!-- Desktop search -->
        <div class="d-none d-lg-flex ms-4" style="flex:1;max-width:380px">
            <div class="input-group forum-search w-100">
                <input type="text" id="searchInput" class="form-control"
                       placeholder="Tìm kiếm bài viết..." autocomplete="off" />
                <button class="btn forum-search-btn" type="button" id="searchBtn">
                    <i class="bi bi-search"></i>
                </button>
            </div>
        </div>

        <button class="navbar-toggler ms-auto me-2 d-lg-none" type="button"
                data-bs-toggle="collapse" data-bs-target="#navContent">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navContent">
            <!-- Mobile search -->
            <div class="d-lg-none my-2">
                <div class="input-group forum-search">
                    <input type="text" id="searchInputMobile" class="form-control"
                           placeholder="Tìm kiếm..." autocomplete="off" />
                    <button class="btn forum-search-btn" type="button" id="searchBtnMobile">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </div>

            <div class="d-flex align-items-center gap-2 ms-lg-auto flex-wrap">

                <a href="/post/create" id="btnNewPost" class="btn btn-primary btn-sm forum-btn-new">
                    <i class="bi bi-plus-lg me-1"></i>Bài viết mới
                </a>

                <!-- Guest buttons -->
                <div id="guestNav" class="d-flex gap-2">
                    <button class="btn btn-outline-light btn-sm"
                            data-bs-toggle="modal" data-bs-target="#loginModal">
                        Đăng nhập
                    </button>
                    <button class="btn btn-light btn-sm fw-semibold"
                            data-bs-toggle="modal" data-bs-target="#registerModal">
                        Đăng ký
                    </button>
                </div>

                <!-- Authenticated user dropdown -->
                <div id="userNav" class="d-none">
                    <div class="dropdown">
                        <button class="btn btn-link p-0 d-flex align-items-center gap-2 text-decoration-none"
                                data-bs-toggle="dropdown">
                            <div class="user-avatar nav-avatar" id="navAvatar">?</div>
                            <span class="text-white fw-medium small" id="navUsername"></span>
                            <i class="bi bi-chevron-down text-white-50" style="font-size:11px"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end forum-dropdown shadow border-0">
                            <li class="px-3 py-2 border-bottom">
                                <div class="fw-semibold small" id="ddUsername"></div>
                                <div class="text-muted" style="font-size:12px" id="ddEmail"></div>
                                <span class="badge mt-1" id="ddRole"
                                      style="font-size:10px;background:var(--forum-accent)"></span>
                            </li>
                            <li>
                                <a class="dropdown-item small" href="/">
                                    <i class="bi bi-house me-2 text-muted"></i>Trang chủ
                                </a>
                            </li>
                            <li><hr class="dropdown-divider my-1"></li>
                            <li>
                                <a class="dropdown-item small text-danger" href="#" id="btnLogout">
                                    <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>

            </div>
        </div>
    </div>
</nav>

<!-- Flash message banner -->
<div id="flashContainer" style="display:none;position:sticky;top:58px;z-index:1040">
    <div class="container-xl pt-2">
        <div id="flashMsg" class="alert alert-dismissible fade show mb-0" role="alert">
            <span id="flashText"></span>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    </div>
</div>

<!-- Main content -->
<main class="container-xl py-4">
    @RenderBody()
</main>

<!-- Footer -->
<footer class="forum-footer mt-5">
    <div class="container-xl d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span class="text-muted small">© 2026 <strong>Forum</strong> — Cộng đồng lập trình viên</span>
        <span class="text-muted small">Built with <i class="bi bi-heart-fill text-danger" style="font-size:11px"></i> ASP.NET Core 6</span>
    </div>
</footer>

<!-- ══════════════ LOGIN MODAL ══════════════ -->
<div class="modal fade" id="loginModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content forum-modal">
            <div class="modal-header border-0 pb-0">
                <div>
                    <h5 class="modal-title fw-bold">Đăng nhập</h5>
                    <p class="text-muted small mb-0">Chào mừng trở lại!</p>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="loginError" class="alert alert-danger py-2 small d-none"></div>
                <form id="loginForm" novalidate>
                    <div class="mb-3">
                        <label class="form-label fw-medium small">Email</label>
                        <input type="email" class="form-control" id="loginEmail"
                               placeholder="your@email.com" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium small">Mật khẩu</label>
                        <div class="input-group">
                            <input type="password" class="form-control" id="loginPassword"
                                   placeholder="Nhập mật khẩu" required />
                            <button class="btn btn-outline-secondary toggle-pwd-btn" type="button"
                                    data-target="loginPassword">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 fw-semibold" id="btnLogin">
                        <span id="loginSpinner" class="spinner-border spinner-border-sm me-2 d-none"></span>
                        Đăng nhập
                    </button>
                </form>
                <div class="text-center mt-3">
                    <span class="text-muted small">Chưa có tài khoản? </span>
                    <a href="#" class="small fw-medium"
                       data-bs-dismiss="modal" data-bs-toggle="modal"
                       data-bs-target="#registerModal">Đăng ký ngay</a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ══════════════ REGISTER MODAL ══════════════ -->
<div class="modal fade" id="registerModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content forum-modal">
            <div class="modal-header border-0 pb-0">
                <div>
                    <h5 class="modal-title fw-bold">Tạo tài khoản</h5>
                    <p class="text-muted small mb-0">Tham gia cộng đồng hôm nay!</p>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="registerError" class="alert alert-danger py-2 small d-none"></div>
                <form id="registerForm" novalidate>
                    <div class="mb-3">
                        <label class="form-label fw-medium small">Tên người dùng</label>
                        <input type="text" class="form-control" id="regUsername"
                               placeholder="Chỉ chữ, số, dấu _ (3–50 ký tự)" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium small">Email</label>
                        <input type="email" class="form-control" id="regEmail"
                               placeholder="your@email.com" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium small">Mật khẩu</label>
                        <div class="input-group">
                            <input type="password" class="form-control" id="regPassword"
                                   placeholder="≥6 ký tự, 1 chữ hoa, 1 số" required />
                            <button class="btn btn-outline-secondary toggle-pwd-btn" type="button"
                                    data-target="regPassword">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium small">Xác nhận mật khẩu</label>
                        <input type="password" class="form-control" id="regConfirmPassword"
                               placeholder="Nhập lại mật khẩu" required />
                    </div>
                    <button type="submit" class="btn btn-primary w-100 fw-semibold" id="btnRegister">
                        <span id="registerSpinner" class="spinner-border spinner-border-sm me-2 d-none"></span>
                        Tạo tài khoản
                    </button>
                </form>
                <div class="text-center mt-3">
                    <span class="text-muted small">Đã có tài khoản? </span>
                    <a href="#" class="small fw-medium"
                       data-bs-dismiss="modal" data-bs-toggle="modal"
                       data-bs-target="#loginModal">Đăng nhập</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>
<script src="~/js/forum.js" asp-append-version="true"></script>
</body>
</html>
