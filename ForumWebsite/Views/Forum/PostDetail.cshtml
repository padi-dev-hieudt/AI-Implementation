@{
    ViewData["Title"] = "Bài viết";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" />
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>
    <script src="~/js/pages/post-detail.js" asp-append-version="true"></script>
}

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb forum-breadcrumb">
        <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
        <li class="breadcrumb-item active" id="breadcrumbTitle">Đang tải...</li>
    </ol>
</nav>

<!-- Post container (populated by forum.js → PostDetail.load) -->
<div id="postContainer">
    <div class="d-flex justify-content-center align-items-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Đang tải...</span>
        </div>
    </div>
</div>

<!-- Comments section (shown after load) -->
<div id="commentsSection" class="d-none mt-3">
    <div class="forum-card">
        <div class="forum-card-header d-flex justify-content-between align-items-center">
            <span class="fw-semibold">
                <i class="bi bi-chat me-1"></i>Bình luận
                (<span id="commentCount">0</span>)
            </span>
        </div>
        <div id="commentsContainer"></div>
    </div>
</div>

<!-- Add-comment form (shown for authenticated users) -->
<div id="commentFormSection" class="mt-3 d-none">
    <div class="forum-card p-3">
        <div class="d-flex gap-3 align-items-start">
            <div class="user-avatar flex-shrink-0" id="commentAvatar">?</div>
            <div class="flex-grow-1">
                <textarea class="form-control" id="commentInput" rows="3"
                          placeholder="Viết bình luận của bạn..."></textarea>
                <div class="d-flex justify-content-between align-items-center mt-2">
                    <small class="text-muted" id="commentCharCount">0 / 5000</small>
                    <button class="btn btn-primary btn-sm" id="btnSubmitComment">
                        <span id="commentSpinner" class="spinner-border spinner-border-sm me-1 d-none"></span>
                        <i class="bi bi-send me-1"></i>Gửi bình luận
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Guest prompt for comments -->
<div id="commentGuestPrompt" class="mt-3 d-none">
    <div class="forum-card p-3 text-center">
        <p class="text-muted mb-2 small">Đăng nhập để tham gia thảo luận</p>
        <button class="btn btn-primary btn-sm"
                data-bs-toggle="modal" data-bs-target="#loginModal">
            <i class="bi bi-box-arrow-in-right me-1"></i>Đăng nhập
        </button>
    </div>
</div>

<!-- Edit post modal -->
<div class="modal fade" id="editPostModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content forum-modal">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Chỉnh sửa bài viết</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="editPostError" class="alert alert-danger py-2 small d-none"></div>
                <div class="mb-3">
                    <label class="form-label fw-medium small">Tiêu đề</label>
                    <input type="text" class="form-control" id="editPostTitle" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-medium small">Nội dung</label>
                    <!-- Quill editor for editing existing post content -->
                    <div id="editPostContentEditor"></div>
                    <input type="hidden" id="editPostContent" />
                </div>
                <div class="d-flex gap-2 justify-content-end">
                    <button class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button class="btn btn-primary" id="btnSaveEditPost">
                        <span id="editPostSpinner" class="spinner-border spinner-border-sm me-1 d-none"></span>
                        Lưu thay đổi
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
